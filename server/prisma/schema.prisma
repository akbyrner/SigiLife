generator client {
  provider = "prisma-client-ts"
  output = "./generated"
}

datasource db {
  provider = "mysql"

}

model User {
  id            Int           @id @default(autoincrement())
  username      String?       @unique @db.VarChar(100)
  email         String        @unique @db.VarChar(255)
  name          String?       @db.VarChar(255)
  picture       String?       @db.VarChar(500)
  googleId      String?       @unique @db.VarChar(255)
  avatar        Int           @default(0)
  theme         Int           @default(1)
  isAdmin       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  homeLocation  String?       @db.VarChar(500)
  sigils        Sigil[]

  @@map("users")
}

model Sigil {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(100)
  userId        Int
  intention     String?       @db.Text
  canvasData    String?       @db.LongText
  imageData     String?       @db.LongText
  isCharged     Boolean       @default(false)
  locationName  String?       @db.VarChar(200)
  latitude      Decimal?      @db.Decimal(10, 8)
  longitude     Decimal?      @db.Decimal(11, 8)
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sigilGroups   SigilGroup[]

  @@unique([userId, name])
  @@map("sigils")
}

model SigilGroup{
  id            Int         @id @default(autoincrement())
  sigilId       Int
  groupMember   String      @db.VarChar(100)
  sigil         Sigil       @relation(fields: [sigilId], references: [id], onDelete: Cascade)

  @@map("sigil_groups")
}

model SvgVector {
  id            Int       @id @default(autoincrement())
  sigilId       Int?      @map("sigil_id")
  filename      String    @db.Text
  vectorData    String    @db.Text   @map("vector_data")
  width         Int
  height        Int
  fileSize      Int       @map("file_size")
  createdAt     DateTime  @default(now())

  @@map("svg_vectors")
}